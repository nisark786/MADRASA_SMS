# Copy this file to .env and configure your production values
# IMPORTANT: Never commit .env to version control

# Database Connection (e.g. Supabase, RDS)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://user:password@host/database

# Redis Connection (Defaults to the docker-compose service name)
REDIS_URL=redis://redis:6379

# Security
# CRITICAL: Generate a strong secret key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Never use the default value in production
SECRET_KEY=paste-your-secure-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial Admin User Credentials
# IMPORTANT: Change these before first deployment!
# Generate a strong password with: python -c "import secrets; print(secrets.token_urlsafe(16))"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# Rate Limiting (requests per minute)
# Login endpoint - protects against brute force attacks
LOGIN_RATE_LIMIT=5
# General API rate limit
API_RATE_LIMIT=60

# Allowed Frontend Origins (CORS)
# e.g., https://your-production-domain.com
FRONTEND_URL=http://localhost:5173

# Email Configuration (SMTP)
# SMTP Server Settings (Gmail example)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Students Data Store

# Email Features
EMAIL_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=false

# Google Drive Configuration (FREE cloud backup storage)
# Set GOOGLE_DRIVE_ENABLED=true to enable automatic backup uploads to Google Drive
GOOGLE_DRIVE_ENABLED=false
GOOGLE_CREDENTIALS_PATH=google-credentials.json
# Optional: Use an existing Google Drive folder ID (create folder manually and get ID from URL)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_BACKUP_FOLDER_NAME=Students Data Store Backups
