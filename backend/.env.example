# Copy this file to .env and configure your production values

# Database Connection (e.g. Supabase, RDS)
DATABASE_URL=postgresql+asyncpg://user:password@host/database

# Redis Connection (Defaults to the docker-compose service name)
REDIS_URL=redis://redis:6379

# Security
# Generate a secret key with: openssl rand -hex 32
SECRET_KEY=paste-your-secure-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Allowed Frontend Origins (CORS)
# e.g., https://your-production-domain.com
FRONTEND_URL=http://localhost:5173
