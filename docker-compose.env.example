# Docker Compose Example - Copy to .env and customize for your environment
# 
# This file shows all required environment variables for docker-compose
# Copy these values to a .env file in the project root
#
# IMPORTANT: NEVER commit actual credentials to version control!

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/students_db

# Redis Configuration
REDIS_URL=redis://redis:6379

# Security - CRITICAL: Generate strong values
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-strong-secret-key-here-32-characters-minimum

# Initial Admin User Credentials
# Change these immediately after first login!
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Rate Limiting
LOGIN_RATE_LIMIT=5
API_RATE_LIMIT=60

# Optional: API Configuration (defaults shown)
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7
